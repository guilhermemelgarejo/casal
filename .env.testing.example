APP_NAME="DuoZen"
APP_ENV=testing
APP_KEY=base64:base64-APP_KEY-aqui
APP_DEBUG=true
APP_URL=http://casal.localhost

APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# IMPORTANTE: ambiente de teste deve ser isolado do MySQL do dev.
DB_CONNECTION=sqlite
DB_DATABASE=:memory:
DB_FOREIGN_KEYS=true

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

DUOZEN_BILLING_DISABLED=true
DUOZEN_SUBSCRIPTION_ADMIN_COUPLE_ID=

