APP_NAME="DuoZen"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://casal.localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Stripe (Laravel Cashier) — assinatura mensal com período de teste
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Price ID mensal criado no Stripe Dashboard (Products → Prices)
STRIPE_PRICE_ID=

# Moeda e locale de faturamento (ex.: brl, pt_BR)
CASHIER_CURRENCY=brl
CASHIER_CURRENCY_LOCALE=pt_BR

# ID do casal cujos membros são sempre admins de assinaturas (1 por omissão; vazio desativa)
DUOZEN_SUBSCRIPTION_ADMIN_COUPLE_ID=1

# E-mails com acesso à área /admin/assinaturas (separados por vírgula)
DUOZEN_ADMIN_EMAILS=

# Isentos de plano (além dos admins), separados por vírgula
DUOZEN_BILLING_EXEMPT_EMAILS=

# Dias de teste após registar cartão no Checkout (mínimo ~3 por requisitos do Stripe)
DUOZEN_TRIAL_DAYS=14

# true = não exige assinatura (útil em dev/testes)
DUOZEN_BILLING_DISABLED=false
